# Copie para config/local.yaml e ajuste IDs Hugging Face dos modelos.

paths:
  project_root: .

huggingface:
  train_repo: zjunlp/WorFBench_train
  test_repo: zjunlp/WorFBench_test

models:
  slm:
    - id: granite-3b
      hf_id: ibm-granite/granite-4.1-3b
    - id: ministral-3-3b
      hf_id: mistralai/Ministral-3-3B-Instruct-2512-BF16
    - id: nemotron-nano-4b
      hf_id: nvidia/NVIDIA-Nemotron-3-Nano-4B-BF16
      trust_remote_code: true
